{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A project tracked by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "client": { "type": "string" },
        "budget": { "type": "number" },
        "estimatedHours": { "type": "number" },
        "actualHours": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold"] },
        "deadline": { "type": "number" },
        "createdAt": { "type": "number" },
        "githubRepo": { "type": "string" },
        "resourceCosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "amount": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "uid", "name", "client", "budget", "status"]
    },
    "TimeEntry": {
      "title": "TimeEntry",
      "description": "A log of hours worked on a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "projectId": { "type": "string" },
        "hours": { "type": "number" },
        "date": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["id", "uid", "projectId", "hours", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects owned by users"
    },
    "/timeEntries/{entryId}": {
      "schema": "TimeEntry",
      "description": "Time logs for projects"
    }
  }
}
